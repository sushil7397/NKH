# Enforce the official public npm registry. Some Sandboxes/CI runners default
# to a mirror or proxy that has produced bogus version data for this repo
# (debug@4.5.0, tailwindcss@3.4.59, postcss-js@4.5.0 — none of which exist on
# the public registry). This file makes the registry choice explicit and
# overrides any user-level or env-level npm config.
registry=https://registry.npmjs.org/

# Lockfile generated locally is not authoritative — CI deletes it before
# installing, so don't waste time auditing it here either.
audit=false
fund=false

# When the lockfile gets out of sync, install instead of aborting.
package-lock=true
